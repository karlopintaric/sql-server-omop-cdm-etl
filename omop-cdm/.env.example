DAGSTER_DEPLOYMENT=dev

DB_SERVER=YOUR_SQL_SERVER
DB_PORT=1433
DB_DATABASE=YOUR_DATABASE
DB_SCHEMA=cdm_omop_dbt
DB_USERNAME=YOUR_USERNAME
DB_PASSWORD=YOUR_PASSWORD

DB_SERVER_DEV=YOUR_DEV_SQL_SERVER
DB_PORT_DEV=1433
DB_DATABASE_DEV=YOUR_DEV_DATABASE
DB_SCHEMA_DEV=stage
DB_USERNAME_DEV=YOUR_DEV_USERNAME
DB_PASSWORD_DEV=YOUR_DEV_PASSWORD

SOURCE_SCHEMA=stage
VOCAB_SCHEMA=cdm_omop_vocabulary
VOCABULARY_S3_BUCKET=raw
VOCABULARY_S3_PATH=omop/vocabulary
VOCAB_CSV_DIR=./data/vocabulary
VOCAB_CSV_DELIMITER=\t
VOCAB_SKIP_MISSING=true
VOCAB_DROP_EXISTING=true

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_KEY=minio123

EXPORT_S3_BUCKET=05-curated
EXPORT_S3_PREFIX=OMOP/template

EXCHANGE_USERNAME=
EXCHANGE_PASSWORD=
EXCHANGE_SERVER=
EXCHANGE_EMAIL=
DAGSTER_UI_URL=http://localhost:3001
SENSOR_INTERVAL=60

# Data-quality containers (each asset can be run independently)
# Leave *_COMMAND empty to use each image default ENTRYPOINT/CMD.
DATA_QUALITY_DASHBOARD_IMAGE=data_quality_dashboard:latest
DATA_QUALITY_DASHBOARD_COMMAND=

CDM_ONBOARDING_IMAGE=cdm_onboarding:latest
CDM_ONBOARDING_COMMAND=

ACHILLES_IMAGE=achilles:latest
ACHILLES_COMMAND=
